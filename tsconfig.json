{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "test-mocks": ["./tests/support/module-mocks.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "scripts/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
