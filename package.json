{
  "name": "ki-skill",
  "version": "0.4.0",
  "description": "Cross-tool skill manager for AI coding assistants",
  "author": "Level",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levelio/ki.git"
  },
  "keywords": ["skill", "ai", "claude", "cursor", "cli"],
  "type": "module",
  "bin": {
    "ki": "dist/cli.js"
  },
  "files": ["dist", "assets"],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "verify": "npm run check && npm test && npm run build",
    "changeset": "changeset",
    "check:changeset": "node scripts/check-changeset.mjs",
    "version-packages": "changeset version && biome format --write package.json package-lock.json",
    "release": "changeset publish",
    "postinstall": "node scripts/postinstall-reminder.mjs",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.6",
    "@types/node": "^24.6.1",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check",
    "pre-push": "npm run verify"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^1.1.0",
    "yaml": "^2.8.2"
  }
}
